  "keywords": [
    "fencing",
    "mqtt",
    "json",
    "openpiste",
    "opp2",
    "iot",
    "esp32",
    "scoring"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenPiste/opp2-library"
  },
  "authors": [
    {
      "name": "Piet Wauters",
      "url": "https://github.com/pietwauters",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "homepage": "https://openpiste.org",
  "dependencies": {
    "bblanchon/ArduinoJson": "^7.0.0"
  },
  "frameworks": [
    "arduino",
    "espidf",
    "*"
  ],
  "platforms": [
    "espressif32",
    "espressif8266",
    "native",
    "*"
  ],
  "build": {
    "srcDir": "src",
    "includeDir": "src"
  }
